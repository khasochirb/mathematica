# URL of the Mathly API (apps/api)
# Local development: http://localhost:3001
# Production: your deployed API URL on Vercel
NEXT_PUBLIC_API_URL=http://localhost:3001

# Auth rate limiting (Upstash Redis) — OPTIONAL.
# When BOTH are set, /api/auth/{login,register,resend} are rate-limited per IP
# (see middleware.ts + lib/rate-limit.ts). When unset, limiting is disabled
# (fail-open) and auth works normally. Provision free via Vercel → Storage →
# Upstash Redis, which injects both vars automatically in production.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# AI tutor (Anthropic Claude) — OPTIONAL.
# When set, /api/tutor is live: students get the in-lesson AI tutor and the
# missed-question explainer (10 questions/day each via FREE_DAILY_AI_LIMIT).
# When unset, the endpoint returns a friendly 503 and the rest of the app is
# unaffected. Create a key at console.anthropic.com → API keys.
ANTHROPIC_API_KEY=
