    {
      "id": "log-inequality",
      "title": "Log inequalities (domain trap)",
      "level": 3,
      "skill": "Solve the inequality AND keep the argument positive — intersect both.",
      "variants": [
        {
          "id": "log-ineq-v1",
          "statement": "Solve: $\\log_{2}(x - 1) < 3$.",
          "options": [
