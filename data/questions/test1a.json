    "difficulty": 1,
    "body": "$\\frac{1}{\\tan x} + \\frac{\\sin x}{1 + \\cos x}$ утгыг ол.",
    "options": {
      "A": "$\\frac{1}{\\cos x}$",
      "B": "$\\cos x$",
      "C": "$\\frac{1}{\\sin x}$",
      "D": "$\\sin x$",
      "E": "$\\frac{1}{1+\\cos x}$"
    },
