      "section": "A",
      "maximumMark": 6,
      "topic": "stats_probability",
      "skill_tag": "conditional_probability",
      "parts": [
        {
          "label": "a",
          "body": "Find the probability that the counter taken is red.",
          "marks": 3,
          "markscheme": [
            {
              "mark": "M1",
              "note": "use the total probability over the two boxes"
            },
            {
              "mark": "A1",
              "note": "$\\tfrac{1}{2}\\cdot\\tfrac{3}{5} + \\tfrac{1}{2}\\cdot\\tfrac{1}{5}$"
            },
            {
              "mark": "A1",
              "note": "$P(R) = \\dfrac{2}{5}$"
            }
          ],
          "answer": "$\\dfrac{2}{5}$",
          "solution": "$$P(R) = \\frac{1}{2}\\cdot\\frac{3}{5} + \\frac{1}{2}\\cdot\\frac{1}{5} = \\frac{3}{10} + \\frac{1}{10} = \\frac{2}{5}$$",
          "verify": [
            "Eq(Rational(1,2)*Rational(3,5) + Rational(1,2)*Rational(1,5), Rational(2,5))"
          ]
        },
        {
          "label": "b",
          "body": "Given that the counter is red, find the probability that it came from box A.",
          "marks": 3,
          "markscheme": [
            {
              "mark": "M1",
              "note": "use $P(A \\mid R) = \\dfrac{P(A \\cap R)}{P(R)}$"
            },
            {
              "mark": "A1",
              "note": "$\\dfrac{3/10}{2/5}$"
            },
            {
              "mark": "A1",
              "note": "$P(A \\mid R) = \\dfrac{3}{4}$"
            }
          ],
          "answer": "$\\dfrac{3}{4}$",
          "solution": "$$P(A \\mid R) = \\frac{\\tfrac{1}{2}\\cdot\\tfrac{3}{5}}{\\tfrac{2}{5}} = \\frac{3/10}{2/5} = \\frac{3}{4}$$",
          "verify": [
            "Eq((Rational(1,2)*Rational(3,5))/Rational(2,5), Rational(3,4))"
          ]
        }
      ],
      "contextIntro": "Box A contains 3 red and 2 green counters; box B contains 1 red and 4 green counters. A fair coin is tossed: heads means a counter is taken at random from box A, tails from box B."
    },
