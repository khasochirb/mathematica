            "Eq(simplify(1/(2 + sqrt(3)) - (2 - sqrt(3))), 0)"
          ]
        },
        {
          "label": "c",
          "body": "Write down the exact value of $\\tan 75^{\\circ} \\times \\tan 15^{\\circ}$.",
          "marks": 2,
          "markscheme": [
            {
              "mark": "M1",
              "note": "$(2 + \\sqrt{3})(2 - \\sqrt{3}) = 4 - 3$"
