        {
          "label": "c",
          "body": "Find the time at which the particle is next at rest after $t = 0$.",
          "marks": 2,
          "markscheme": [
            {
              "mark": "M1",
              "note": "$v = 0$ when $\\sin t = 0$"
            },
            {
              "mark": "A1",
              "note": "$t = \\pi \\; (= 3.14)$ seconds"
            }
          ],
          "answer": "$t = \\pi \\approx 3.14$ s",
          "solution": "$e^{-0.2t} > 0$ always, so $v = 0$ requires $\\sin t = 0$: the next time is $t = \\pi \\approx 3.14$ s.",
          "verify": [
            "Eq(sin(pi), 0)",
            "Abs(pi - 3.14) < 0.005"
          ]
        },
        {
