          "markscheme": [
            {
              "mark": "M1",
              "note": "substitute $t = 10$"
            },
            {
              "mark": "A1",
              "note": "$T(10) = 47.6\\,^{\\circ}$C $(47.6139\\ldots)$"
            }
          ],
          "answer": "$47.6\\,^{\\circ}$C",
          "solution": "$$T(10) = 22 + 63e^{-0.9} = 47.6139 \\approx 47.6\\,^{\\circ}\\text{C}.$$",
          "verify": [
            "Abs(22 + 63*exp(Rational(-9,10)) - 47.6) < 0.051000000000000004"
          ]
        },
        {
          "label": "c",
          "body": "Find how long it takes for the temperature to reach $40\\,^{\\circ}$C.",
          "marks": 3,
          "markscheme": [
            {
              "mark": "M1",
              "note": "$63e^{-0.09t} = 18$"
            },
            {
              "mark": "A1",
              "note": "$e^{-0.09t} = \\dfrac{2}{7}$"
            },
            {
              "mark": "A1",
              "note": "$t = 13.9$ minutes $(13.9196\\ldots)$"
            }
          ],
          "answer": "$t = 13.9$ minutes",
          "solution": "$$22 + 63e^{-0.09t} = 40 \\Rightarrow e^{-0.09t} = \\frac{18}{63} = \\frac{2}{7}$$$$t = \\frac{\\ln(7/2)}{0.09} = 13.9196 \\approx 13.9 \\text{ minutes}.$$",
          "verify": [
            "Abs(log(Rational(7,2))/Rational(9,100) - 13.9) < 0.051000000000000004"
          ]
        },
        {
          "label": "d",
          "body": "State the temperature the model predicts the coffee approaches for large $t$.",
          "marks": 1,
          "markscheme": [
            {
              "mark": "A1",
              "note": "$22\\,^{\\circ}$C (room temperature)"
            }
          ],
          "answer": "$22\\,^{\\circ}$C",
          "solution": "As $t \\to \\infty$, $e^{-0.09t} \\to 0$, so $T \\to 22\\,^{\\circ}$C.",
          "verify": [
            "Eq(22 + 63*0, 22)"
          ]
        }
      ],
      "contextIntro": "A cup of coffee cools so that its temperature, in $^{\\circ}$C, after $t$ minutes is modelled by $T(t) = 22 + 63e^{-0.09t}$, $t \\ge 0$."
    },
    {
