    {
      "source": "IB-AAHL-P2-T1-Q6",
      "number": 6,
      "section": "A",
      "maximumMark": 8,
      "topic": "functions",
      "skill_tag": "rational_functions",
      "parts": [
        {
          "label": "a",
          "body": "Write down the equations of the two asymptotes of the graph of $f$.",
          "marks": 2,
          "markscheme": [
            {
              "mark": "A1",
              "note": "vertical: $x = -3$"
            },
            {
              "mark": "A1",
              "note": "horizontal: $y = 2$"
            }
          ],
          "answer": "$x = -3$ and $y = 2$",
          "solution": "The denominator vanishes at $x = -3$ (vertical asymptote); as $x \\to \\pm\\infty$, $f(x) \\to 2$ (horizontal asymptote).",
          "verify": [
            "Eq(solve(Eq(x + 3, 0), x)[0], -3)",
            "Eq(limit((2*x - 1)/(x + 3), x, oo), 2)"
          ]
        },
        {
          "label": "b",
          "body": "Find an expression for $f^{-1}(x)$.",
          "marks": 3,
          "markscheme": [
            {
              "mark": "M1",
              "note": "set $x = \\dfrac{2y - 1}{y + 3}$ and clear the fraction"
            },
            {
              "mark": "A1",
              "note": "$y(x - 2) = -3x - 1$"
            },
            {
              "mark": "A1",
              "note": "$f^{-1}(x) = \\dfrac{3x + 1}{2 - x}$, $x \\ne 2$"
            }
          ],
          "answer": "$f^{-1}(x) = \\dfrac{3x + 1}{2 - x}$",
          "solution": "$$x = \\frac{2y - 1}{y + 3} \\Rightarrow xy + 3x = 2y - 1 \\Rightarrow y(x - 2) = -3x - 1$$$$f^{-1}(x) = \\frac{3x + 1}{2 - x}, \\quad x \\ne 2.$$",
          "verify": [
            "Eq(simplify(((2*((3*x + 1)/(2 - x)) - 1)/(((3*x + 1)/(2 - x)) + 3)) - x), 0)"
          ]
        },
        {
          "label": "c",
          "body": "Show that the equation $f(x) = x$ has no real solutions.",
          "marks": 3,
          "markscheme": [
            {
              "mark": "M1",
              "note": "$2x - 1 = x(x + 3)$"
            },
            {
              "mark": "A1",
              "note": "$x^2 + x + 1 = 0$ with discriminant $1 - 4 = -3$"
            },
            {
              "mark": "AG",
              "note": "$\\Delta < 0$, so no real solutions"
            }
          ],
          "answer": "no real solutions ($\\Delta = -3 < 0$)",
          "solution": "$$\\frac{2x - 1}{x + 3} = x \\Rightarrow 2x - 1 = x^2 + 3x \\Rightarrow x^2 + x + 1 = 0$$The discriminant is $1 - 4 = -3 < 0$, so the quadratic — and hence $f(x) = x$ — has no real solutions.",
          "verify": [
            "Eq(expand(x*(x + 3) - (2*x - 1)), x**2 + x + 1)",
            "Eq(1 - 4, -3)",
            "-3 < 0"
          ]
        }
      ],
      "contextIntro": "The function $f$ is defined by $f(x) = \\dfrac{2x - 1}{x + 3}$ for $x \\ne -3$."
    },
