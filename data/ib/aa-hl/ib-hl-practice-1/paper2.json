    {
      "source": "IB-AAHL-P2-T1-Q1",
      "number": 1,
      "section": "A",
      "maximumMark": 7,
      "topic": "geometry_trig",
      "skill_tag": "non_right_trig",
      "parts": [
        {
          "label": "a",
          "body": "Find the length of $BC$.",
          "marks": 3,
          "markscheme": [
            {
              "mark": "M1",
              "note": "cosine rule: $BC^2 = 11^2 + 8^2 - 2(11)(8)\\cos 37^{\\circ}$"
            },
            {
              "mark": "A1",
              "note": "$BC^2 = 44.4402$"
            },
            {
              "mark": "A1",
              "note": "$BC = 6.67$ cm $(6.66634\\ldots)$"
            }
          ],
          "answer": "$BC = 6.67$ cm",
          "solution": "$$BC^2 = 11^2 + 8^2 - 2(11)(8)\\cos 37^{\\circ} = 44.4402$$$$BC = 6.66634 \\approx 6.67 \\text{ cm}.$$",
          "verify": [
            "Abs(sqrt(11**2 + 8**2 - 176*cos(rad(37))) - 6.67) < 0.0051"
          ]
        },
        {
          "label": "b",
          "body": "Find the area of triangle $ABC$.",
          "marks": 2,
          "markscheme": [
            {
              "mark": "M1",
              "note": "area $= \\tfrac{1}{2}(11)(8)\\sin 37^{\\circ}$"
            },
            {
              "mark": "A1",
              "note": "area $= 26.5$ cm$^2$ $(26.4799\\ldots)$"
            }
          ],
          "answer": "$26.5$ cm$^2$",
          "solution": "$$\\text{Area} = \\tfrac{1}{2}(11)(8)\\sin 37^{\\circ} = 26.4799 \\approx 26.5 \\text{ cm}^2.$$",
          "verify": [
            "Abs(Rational(1,2)*88*sin(rad(37)) - 26.5) < 0.051000000000000004"
          ]
        },
        {
          "label": "c",
          "body": "Find the shortest distance from $C$ to the line $(AB)$.",
          "marks": 2,
          "markscheme": [
            {
              "mark": "M1",
              "note": "area $= \\tfrac{1}{2} \\times AB \\times h$, so $h = \\dfrac{2 \\times \\text{area}}{8}$"
            },
            {
              "mark": "A1",
              "note": "$h = 6.62$ cm"
            }
          ],
          "answer": "$6.62$ cm",
          "solution": "The shortest distance is the height from $C$ onto $AB$:$$h = \\frac{2 \\times 26.4799}{8} = 6.61997 \\approx 6.62 \\text{ cm}.$$",
          "verify": [
            "Abs(11*sin(rad(37)) - 6.62) < 0.0051"
          ]
        }
      ],
      "contextIntro": "In triangle $ABC$, $AB = 8$ cm, $AC = 11$ cm and $B\\hat{A}C = 37^{\\circ}$.",
      "figure": {
        "src": "/ib-figures/ib-aahl-p2-t1-q1.png",
        "width": 607,
        "height": 502,
        "alt_en": "Triangle ABC with AB = 8 cm along the base, AC = 11 cm, and the 37 degree angle at A marked with an arc."
      }
    },
    {
      "source": "IB-AAHL-P2-T1-Q2",
      "number": 2,
      "section": "A",
      "maximumMark": 7,
      "topic": "stats_probability",
      "skill_tag": "normal_distribution",
      "parts": [
        {
          "label": "a",
          "body": "Find $P(X > 75)$.",
          "marks": 2,
          "markscheme": [
            {
              "mark": "M1",
              "note": "standardise or use the GDC normal cdf"
            },
            {
              "mark": "A1",
              "note": "$P(X > 75) = 0.0808$ $(0.0807567\\ldots)$"
            }
          ],
          "answer": "$0.0808$",
          "solution": "$$P(X > 75) = P\\Big(Z > \\frac{75 - 68}{5}\\Big) = P(Z > 1.4) = 0.0807567 \\approx 0.0808.$$",
          "verify": [
            "Abs((1 - (1 + erf(Rational(7,5)/sqrt(2)))/2) - 0.0808) < 5.1000000000000006e-05"
          ]
        },
        {
          "label": "b",
          "body": "Find $P(60 < X < 75)$.",
          "marks": 2,
          "markscheme": [
            {
              "mark": "M1",
              "note": "GDC normal cdf between 60 and 75"
            },
            {
              "mark": "A1",
              "note": "$P(60 < X < 75) = 0.864$ $(0.864444\\ldots)$"
            }
          ],
          "answer": "$0.864$",
          "solution": "$$P(60 < X < 75) = \\Phi(1.4) - \\Phi(-1.6) = 0.864444 \\approx 0.864.$$",
          "verify": [
            "Abs(((1 + erf(Rational(7,5)/sqrt(2)))/2 - (1 + erf(Rational(-8,5)/sqrt(2)))/2) - 0.864) < 0.00051"
          ]
        },
        {
          "label": "c",
          "body": "The top 20% of scores receive a distinction. Find the minimum score needed for a distinction.",
          "marks": 3,
          "markscheme": [
            {
              "mark": "M1",
              "note": "$P(X > k) = 0.2$, use the inverse normal"
            },
            {
              "mark": "A1",
              "note": "$z = 0.8416\\ldots$"
            },
            {
              "mark": "A1",
              "note": "$k = 72.2$ $(72.2081\\ldots)$"
            }
          ],
          "answer": "$k = 72.2$",
          "solution": "$P(X > k) = 0.2$ means $\\Phi\\big(\\tfrac{k - 68}{5}\\big) = 0.8$, so $\\tfrac{k - 68}{5} = 0.841621\\ldots$ and$$k = 68 + 5(0.841621\\ldots) = 72.2081 \\approx 72.2.$$",
          "verify": [
            "Abs((68 + 5*sqrt(2)*erfinv(Rational(3,5))) - 72.2) < 0.051000000000000004"
          ]
        }
      ],
      "contextIntro": "The scores $X$ in an examination are normally distributed: $X \\sim N(68, 5^2)$."
    },
    {
      "source": "IB-AAHL-P2-T1-Q3",
      "number": 3,
      "section": "A",
      "maximumMark": 7,
      "topic": "number_algebra",
      "skill_tag": "compound_interest",
      "parts": [
        {
          "label": "a",
          "body": "Find the value of the investment after 6 years, giving your answer to two decimal places.",
          "marks": 3,
          "markscheme": [
            {
              "mark": "M1",
              "note": "use $V = 5000\\left(1 + \\tfrac{0.048}{4}\\right)^{4n}$"
            },
            {
              "mark": "A1",
              "note": "$V = 5000(1.012)^{24}$"
            },
            {
              "mark": "A1",
              "note": "$V = \\$6657.36$"
            }
          ],
          "answer": "$\\$6657.36$",
          "solution": "Quarterly rate $= 0.048/4 = 0.012$, with $24$ quarters in 6 years:$$V = 5000(1.012)^{24} = 6657.36.$$",
          "verify": [
            "Abs(5000*(Rational(1012,1000))**24 - 6657.36) < 0.005"
          ]
        },
        {
          "label": "b",
          "body": "Find the least number of complete years needed for the investment to exceed \\$8000.",
          "marks": 4,
          "markscheme": [
            {
              "mark": "M1",
              "note": "solve $5000(1.012)^{4n} > 8000$"
            },
            {
              "mark": "A1",
              "note": "$(1.012)^{4n} > 1.6$, so $4n > 39.4$ quarters"
            },
            {
              "mark": "M1",
              "note": "check whole years: after 9 years \\$7681.90, after 10 years \\$8057.32"
            },
            {
              "mark": "A1",
              "note": "least $n = 10$ years"
            }
          ],
          "answer": "$10$ years",
          "solution": "$$5000(1.012)^{4n} > 8000 \\Rightarrow (1.012)^{4n} > 1.6 \\Rightarrow 4n > \\frac{\\ln 1.6}{\\ln 1.012} = 39.40\\ldots$$After 9 years the value is \\$7681.90 $< 8000$; after 10 years it is \\$8057.32 $> 8000$. The least number of complete years is $10$.",
          "verify": [
            "5000*(Rational(1012,1000))**36 < 8000",
            "5000*(Rational(1012,1000))**40 > 8000",
            "Abs(log(Rational(8,5))/log(Rational(1012,1000)) - 39.4) < 0.05"
          ]
        }
      ],
      "contextIntro": "Tuya invests \\$5000 in an account paying a nominal annual interest rate of 4.8%, compounded quarterly."
    },
    {
