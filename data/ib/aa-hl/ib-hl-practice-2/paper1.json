            "Eq(2*sqrt(2)*sin(-pi/4), -2)"
          ]
        },
        {
          "label": "c",
          "body": "Find $z^2$, giving your answer in the form $a + bi$.",
          "marks": 2,
          "markscheme": [
            {
              "mark": "M1",
              "note": "expand $(2 - 2i)^2$"
            },
            {
              "mark": "A1",
              "note": "$z^2 = -8i$"
            }
          ],
          "answer": "$z^2 = -8i$",
          "solution": "$$z^2 = (2 - 2i)^2 = 4 - 8i + 4i^2 = 4 - 8i - 4 = -8i.$$",
          "verify": [
            "Eq(expand((2 - 2*I)**2), -8*I)"
          ]
        }
      ],
      "contextIntro": "Let $z = 2 - 2i$."
    },
    {
