    {
      "source": "IB-AAHL-P1-T2-Q1",
      "number": 1,
      "section": "A",
      "maximumMark": 5,
      "topic": "number_algebra",
      "skill_tag": "counting",
      "parts": [
        {
          "label": "a",
          "body": "Find the number of different committees that can be formed.",
          "marks": 2,
          "markscheme": [
            {
              "mark": "M1",
              "note": "choose $4$ from $11$: $\\binom{11}{4}$"
            },
            {
              "mark": "A1",
              "note": "$330$"
            }
          ],
          "answer": "$330$",
          "solution": "$$\\binom{11}{4} = \\frac{11!}{4!\\,7!} = 330.$$",
          "verify": [
            "Eq(binomial(11, 4), 330)"
          ]
        },
        {
          "label": "b",
          "body": "Find the number of committees that contain exactly $2$ men and $2$ women.",
          "marks": 3,
          "markscheme": [
            {
              "mark": "M1",
              "note": "multiply independent choices $\\binom{6}{2}$ and $\\binom{5}{2}$"
            },
            {
              "mark": "A1",
              "note": "$15 \\times 10$"
            },
            {
              "mark": "A1",
              "note": "$150$"
            }
          ],
          "answer": "$150$",
          "solution": "$$\\binom{6}{2}\\binom{5}{2} = 15 \\times 10 = 150.$$",
          "verify": [
            "Eq(binomial(6, 2)*binomial(5, 2), 150)"
          ]
        }
      ],
      "contextIntro": "A committee of $4$ people is to be chosen from a group of $6$ men and $5$ women."
    },
    {
