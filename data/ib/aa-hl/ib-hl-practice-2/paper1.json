    {
      "source": "IB-AAHL-P1-T2-Q8",
      "number": 8,
      "section": "B",
      "maximumMark": 21,
      "topic": "geometry_trig",
      "skill_tag": "vectors_lines",
      "parts": [
        {
          "label": "a",
          "body": "Find the acute angle between the two lines.",
          "marks": 3,
          "markscheme": [
            {
              "mark": "M1",
              "note": "$\\cos\\theta = \\dfrac{|\\mathbf{d}_1\\cdot\\mathbf{d}_2|}{|\\mathbf{d}_1||\\mathbf{d}_2|}$"
            },
            {
              "mark": "A1",
              "note": "$\\mathbf{d}_1\\cdot\\mathbf{d}_2 = 1$, $|\\mathbf{d}_1| = |\\mathbf{d}_2| = \\sqrt2$"
            },
            {
              "mark": "A1",
              "note": "$\\cos\\theta = \\dfrac12 \\Rightarrow \\theta = 60^\\circ$"
            }
          ],
          "answer": "$60^\\circ$",
          "solution": "$$\\cos\\theta = \\frac{|(1)(0)+(0)(1)+(1)(1)|}{\\sqrt2\\,\\sqrt2} = \\frac12 \\Rightarrow \\theta = 60^\\circ.$$",
          "verify": [
            "Eq(Matrix([1,0,1]).dot(Matrix([0,1,1])), 1)",
            "Eq(Matrix([1,0,1]).norm(), sqrt(2))"
          ]
        },
        {
          "label": "b",
          "body": "Show that $L_1$ and $L_2$ do not intersect, and hence that they are skew.",
          "marks": 4,
          "markscheme": [
            {
              "mark": "M1",
              "note": "equate components: $1 + \\lambda = 0$, $0 = 1 + \\mu$, $2 + \\lambda = \\mu$"
            },
            {
              "mark": "A1",
              "note": "first two give $\\lambda = -1$, $\\mu = -1$"
            },
            {
              "mark": "M1",
              "note": "test in the third equation: $2 + (-1) = 1 \\ne -1$"
            },
            {
              "mark": "AG",
              "note": "no consistent $(\\lambda, \\mu)$, and the directions are not parallel, so the lines are skew"
            }
          ],
          "answer": "the lines are skew",
          "solution": "Equating components: $1+\\lambda = 0$ gives $\\lambda = -1$; $0 = 1+\\mu$ gives $\\mu = -1$. The third equation would need $2 + (-1) = -1$, i.e. $1 = -1$, which is false. The directions $(1,0,1)$ and $(0,1,1)$ are not parallel, so the lines neither intersect nor are parallel: they are skew.",
          "verify": [
            "Eq(1 + (-1), 0)",
            "Eq(2 + (-1), 1)",
            "1 != -1"
          ]
        },
        {
          "label": "c",
          "body": "Find $\\mathbf{d}_1 \\times \\mathbf{d}_2$.",
          "marks": 3,
          "markscheme": [
            {
              "mark": "M1",
              "note": "evaluate the vector-product determinant"
            },
            {
              "mark": "A1",
              "note": "components $(0\\cdot1 - 1\\cdot1,\\; 1\\cdot0 - 1\\cdot1,\\; 1\\cdot1 - 0\\cdot0)$"
            },
            {
              "mark": "A1",
              "note": "$\\mathbf{d}_1\\times\\mathbf{d}_2 = \\begin{pmatrix}-1\\\\-1\\\\1\\end{pmatrix}$"
            }
          ],
          "answer": "$(-1, -1, 1)$",
          "solution": "$$\\mathbf{d}_1\\times\\mathbf{d}_2 = \\begin{vmatrix}\\mathbf{i}&\\mathbf{j}&\\mathbf{k}\\\\1&0&1\\\\0&1&1\\end{vmatrix} = (-1, -1, 1).$$",
          "verify": [
            "Eq(0*1 - 1*1, -1)",
            "Eq(1*0 - 1*1, -1)",
            "Eq(1*1 - 0*0, 1)"
          ]
        },
        {
          "label": "d",
          "body": "Hence find the shortest distance between $L_1$ and $L_2$.",
          "marks": 4,
          "markscheme": [
            {
              "mark": "M1",
              "note": "$\\text{dist} = \\dfrac{|(\\mathbf{a}_2 - \\mathbf{a}_1)\\cdot(\\mathbf{d}_1\\times\\mathbf{d}_2)|}{|\\mathbf{d}_1\\times\\mathbf{d}_2|}$"
            },
