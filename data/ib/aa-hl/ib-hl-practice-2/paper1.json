      "skill_tag": "probability_basics",
      "parts": [
        {
          "label": "a",
          "body": "Find the probability that both counters are red.",
          "marks": 3,
          "markscheme": [
            {
              "mark": "M1",
              "note": "$\\dfrac{\\binom{5}{2}}{\\binom{8}{2}}$ (or $\\tfrac58 \\cdot \\tfrac47$)"
            },
            {
              "mark": "A1",
              "note": "$\\dfrac{10}{28}$"
            },
            {
              "mark": "A1",
              "note": "$\\dfrac{5}{14}$"
            }
          ],
          "answer": "$\\dfrac{5}{14}$",
          "solution": "$$P(RR) = \\frac{\\binom{5}{2}}{\\binom{8}{2}} = \\frac{10}{28} = \\frac{5}{14}.$$",
          "verify": [
            "Eq(binomial(5, 2)/binomial(8, 2), Rational(5, 14))"
          ]
        },
        {
          "label": "b",
          "body": "Find the probability that exactly one counter is red.",
          "marks": 3,
          "markscheme": [
            {
              "mark": "M1",
              "note": "one red and one blue: $\\dfrac{\\binom{5}{1}\\binom{3}{1}}{\\binom{8}{2}}$"
            },
            {
              "mark": "A1",
              "note": "$\\dfrac{15}{28}$"
            },
            {
              "mark": "A1",
              "note": "accept equivalent working $2 \\cdot \\tfrac58 \\cdot \\tfrac37$"
            }
          ],
          "answer": "$\\dfrac{15}{28}$",
          "solution": "$$P(\\text{one red}) = \\frac{\\binom{5}{1}\\binom{3}{1}}{\\binom{8}{2}} = \\frac{15}{28}.$$",
          "verify": [
            "Eq((5*3)/binomial(8, 2), Rational(15, 28))"
          ]
        }
      ],
      "contextIntro": "A bag contains $5$ red counters and $3$ blue counters. Two counters are drawn at random, without replacement."
    },
    {
      "source": "IB-AAHL-P1-T2-Q3",
      "number": 3,
      "section": "A",
      "maximumMark": 9,
      "topic": "functions",
      "skill_tag": "rational_functions",
      "parts": [
        {
          "label": "a",
          "body": "Write down the equation of the vertical asymptote, and find the equation of the oblique (slant) asymptote.",
          "marks": 3,
          "markscheme": [
            {
              "mark": "A1",
              "note": "vertical asymptote $x = 1$"
            },
            {
              "mark": "M1",
              "note": "divide: $\\dfrac{x^2 - 4}{x - 1} = x + 1 - \\dfrac{3}{x - 1}$"
            },
            {
              "mark": "A1",
              "note": "oblique asymptote $y = x + 1$"
            }
          ],
          "answer": "$x = 1$ and $y = x + 1$",
          "solution": "Polynomial division gives$$f(x) = x + 1 - \\frac{3}{x - 1},$$ so the vertical asymptote is $x = 1$ and the oblique asymptote is $y = x + 1$.",
          "verify": [
            "Eq(simplify((x**2 - 4)/(x - 1) - (x + 1 - 3/(x - 1))), 0)"
          ]
        },
        {
          "label": "b",
          "body": "Find the coordinates of the points where the graph of $f$ meets the axes.",
          "marks": 2,
          "markscheme": [
            {
              "mark": "A1",
              "note": "$x$-intercepts $(2, 0)$ and $(-2, 0)$"
            },
            {
              "mark": "A1",
              "note": "$y$-intercept $(0, 4)$"
            }
          ],
          "answer": "$(2, 0)$, $(-2, 0)$, $(0, 4)$",
          "solution": "$f(x) = 0$ when $x^2 - 4 = 0$, i.e. $x = \\pm 2$; and $f(0) = \\dfrac{-4}{-1} = 4$.",
          "verify": [
            "Eq((2**2 - 4), 0)",
            "Eq(((-2)**2 - 4), 0)",
            "Eq((0**2 - 4)/(0 - 1), 4)"
          ]
        },
        {
          "label": "c",
          "body": "Show that $f$ has no stationary points.",
          "marks": 4,
          "markscheme": [
            {
              "mark": "M1",
              "note": "use the quotient rule"
            },
            {
              "mark": "A1",
              "note": "$f'(x) = \\dfrac{x^2 - 2x + 4}{(x - 1)^2}$"
            },
            {
              "mark": "M1",
              "note": "stationary points need the numerator $= 0$"
            },
            {
              "mark": "AG",
              "note": "the discriminant $(-2)^2 - 4(4) = -12 < 0$, so there are no real solutions"
            }
          ],
          "answer": "no stationary points (numerator has no real zeros)",
          "solution": "By the quotient rule,$$f'(x) = \\frac{2x(x - 1) - (x^2 - 4)}{(x - 1)^2} = \\frac{x^2 - 2x + 4}{(x - 1)^2}.$$ A stationary point needs $x^2 - 2x + 4 = 0$, but its discriminant is $(-2)^2 - 4(1)(4) = -12 < 0$, so there are no real solutions and hence no stationary points.",
          "verify": [
            "Eq(simplify(diff((x**2 - 4)/(x - 1), x) - (x**2 - 2*x + 4)/(x - 1)**2), 0)",
            "Eq((-2)**2 - 4*4, -12)"
          ]
        }
      ],
      "contextIntro": "The function $f$ is defined by $f(x) = \\dfrac{x^2 - 4}{x - 1}$, $x \\ne 1$."
    },
    {
