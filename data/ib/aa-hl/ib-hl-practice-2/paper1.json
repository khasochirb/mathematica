          ]
        },
        {
          "label": "c",
          "body": "Find all solutions of the original equation in $0 \\le x \\le 2\\pi$.",
          "marks": 3,
          "markscheme": [
            {
              "mark": "M1",
              "note": "$\\cos x = \\tfrac12$ in $[0, 2\\pi]$"
            },
            {
              "mark": "A1",
              "note": "$x = \\dfrac{\\pi}{3}$"
            },
            {
              "mark": "A1",
              "note": "$x = \\dfrac{5\\pi}{3}$"
            }
          ],
          "answer": "$x = \\dfrac{\\pi}{3}$ and $x = \\dfrac{5\\pi}{3}$",
          "solution": "$$\\cos x = \\frac12 \\Rightarrow x = \\frac{\\pi}{3} \\text{ or } x = 2\\pi - \\frac{\\pi}{3} = \\frac{5\\pi}{3}.$$",
