      "parts": [
        {
          "label": "a",
          "body": "Show that the equation can be written as $2\\cos^2 x + 3\\cos x - 2 = 0$.",
          "marks": 2,
          "markscheme": [
            {
              "mark": "M1",
              "note": "replace $\\sin^2 x$ with $1 - \\cos^2 x$"
            },
            {
              "mark": "AG",
              "note": "$2(1 - \\cos^2 x) - 3\\cos x = 0 \\Rightarrow 2\\cos^2 x + 3\\cos x - 2 = 0$"
            }
          ],
          "answer": "$2\\cos^2 x + 3\\cos x - 2 = 0$",
          "solution": "$$2(1 - \\cos^2 x) - 3\\cos x = 0 \\Rightarrow -2\\cos^2 x - 3\\cos x + 2 = 0 \\Rightarrow 2\\cos^2 x + 3\\cos x - 2 = 0.$$",
          "verify": [
            "Eq(expand(2*(1 - cos(x)**2) - 3*cos(x)), expand(-(2*cos(x)**2 + 3*cos(x) - 2)))"
          ]
        },
        {
          "label": "b",
          "body": "Hence solve $2\\cos^2 x + 3\\cos x - 2 = 0$ for $\\cos x$.",
          "marks": 3,
          "markscheme": [
            {
              "mark": "M1",
              "note": "factor: $(2\\cos x - 1)(\\cos x + 2) = 0$"
            },
            {
              "mark": "A1",
              "note": "$\\cos x = \\dfrac{1}{2}$ or $\\cos x = -2$"
