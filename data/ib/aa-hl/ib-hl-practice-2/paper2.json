    {
      "source": "IB-AAHL-P2-T2-Q1",
      "number": 1,
      "section": "A",
      "maximumMark": 7,
      "topic": "geometry_trig",
      "skill_tag": "non_right_trig",
      "parts": [
        {
          "label": "a",
          "body": "Find the size of the largest angle of the triangle.",
          "marks": 3,
          "markscheme": [
            {
              "mark": "M1",
              "note": "the largest angle is opposite the longest side; cosine rule $\\cos C = \\dfrac{8^2 + 11^2 - 15^2}{2(8)(11)}$"
            },
            {
              "mark": "A1",
              "note": "$\\cos C = -\\dfrac{40}{176}$"
            },
            {
              "mark": "A1",
              "note": "$C = 103^\\circ$ $(103.137\\ldots)$"
            }
          ],
          "answer": "$C = 103^\\circ$",
          "solution": "$$\\cos C = \\frac{8^2 + 11^2 - 15^2}{2(8)(11)} = -\\frac{40}{176} \\Rightarrow C = 103.137 \\approx 103^\\circ.$$",
          "verify": [
            "Abs(deg(acos(Rational(-40, 176))) - 103) < 0.51"
          ]
        },
        {
          "label": "b",
          "body": "Find the area of the triangle.",
          "marks": 2,
          "markscheme": [
            {
              "mark": "M1",
              "note": "area $= \\tfrac12(8)(11)\\sin C$"
            },
            {
              "mark": "A1",
              "note": "area $= 42.8$ $(42.8486\\ldots)$"
            }
          ],
          "answer": "$42.8$",
          "solution": "$$\\text{Area} = \\tfrac12(8)(11)\\sin C = 42.8486 \\approx 42.8.$$",
          "verify": [
            "Abs(Rational(1,2)*88*sin(acos(Rational(-40,176))) - 42.8) < 0.051000000000000004"
          ]
        },
        {
          "label": "c",
          "body": "Find the shortest distance from $C$ to the side $[AB]$.",
          "marks": 2,
          "markscheme": [
            {
              "mark": "M1",
              "note": "area $= \\tfrac12 \\times AB \\times h$, so $h = \\dfrac{2 \\times \\text{area}}{15}$"
            },
            {
              "mark": "A1",
              "note": "$h = 5.71$"
            }
          ],
          "answer": "$h = 5.71$",
          "solution": "The shortest distance is the altitude to $[AB]$:$$h = \\frac{2 \\times 42.8486}{15} = 5.71314 \\approx 5.71.$$",
          "verify": [
            "Abs(2*Rational(1,2)*88*sin(acos(Rational(-40,176)))/15 - 5.71) < 0.0051"
          ]
        }
      ],
      "contextIntro": "In triangle $ABC$, $AB = 15$, $BC = 8$ and $AC = 11$.",
      "figure": {
        "src": "/ib-figures/ib-aahl-p2-t2-q1.png",
        "width": 752,
        "height": 369,
        "alt_en": "Triangle ABC with the longest side AB = 15 as the base, AC = 11 and BC = 8."
      }
    },
    {
      "source": "IB-AAHL-P2-T2-Q2",
      "number": 2,
      "section": "A",
      "maximumMark": 7,
      "topic": "stats_probability",
      "skill_tag": "binomial_distribution",
      "parts": [
        {
          "label": "a",
          "body": "Find $P(X = 6)$.",
          "marks": 2,
          "markscheme": [
            {
              "mark": "M1",
              "note": "binomial pdf (GDC)"
            },
            {
              "mark": "A1",
              "note": "$P(X = 6) = 0.192$ $(0.191639\\ldots)$"
            }
          ],
          "answer": "$0.192$",
          "solution": "$$P(X = 6) = \\binom{20}{6}(0.3)^6(0.7)^{14} = 0.191639 \\approx 0.192.$$",
          "verify": [
            "Abs(binomial(20, 6)*Rational(3,10)**6*Rational(7,10)**14 - 0.192) < 0.00051"
          ]
        },
        {
          "label": "b",
          "body": "Find $P(X \\ge 8)$.",
          "marks": 3,
          "markscheme": [
            {
              "mark": "M1",
              "note": "use the complement $1 - P(X \\le 7)$ (GDC binomial cdf)"
            },
            {
              "mark": "A1",
              "note": "$P(X \\le 7) = 0.772\\ldots$"
            },
            {
              "mark": "A1",
              "note": "$P(X \\ge 8) = 0.228$ $(0.227728\\ldots)$"
            }
          ],
          "answer": "$0.228$",
          "solution": "$$P(X \\ge 8) = 1 - P(X \\le 7) = 0.227728 \\approx 0.228.$$",
          "verify": [
            "Abs((1 - (binomial(20, 0)*Rational(3,10)**0*Rational(7,10)**20 + binomial(20, 1)*Rational(3,10)**1*Rational(7,10)**19 + binomial(20, 2)*Rational(3,10)**2*Rational(7,10)**18 + binomial(20, 3)*Rational(3,10)**3*Rational(7,10)**17 + binomial(20, 4)*Rational(3,10)**4*Rational(7,10)**16 + binomial(20, 5)*Rational(3,10)**5*Rational(7,10)**15 + binomial(20, 6)*Rational(3,10)**6*Rational(7,10)**14 + binomial(20, 7)*Rational(3,10)**7*Rational(7,10)**13)) - 0.228) < 0.00051"
          ]
        },
        {
          "label": "c",
          "body": "Find $E(X)$ and $\\operatorname{Var}(X)$.",
          "marks": 2,
          "markscheme": [
            {
              "mark": "A1",
              "note": "$E(X) = np = 6$"
            },
            {
              "mark": "A1",
              "note": "$\\operatorname{Var}(X) = np(1-p) = 4.2$"
            }
          ],
          "answer": "$E(X) = 6$, $\\operatorname{Var}(X) = 4.2$",
          "solution": "$$E(X) = 20(0.3) = 6, \\qquad \\operatorname{Var}(X) = 20(0.3)(0.7) = 4.2.$$",
          "verify": [
            "Eq(20*Rational(3, 10), 6)",
            "Eq(20*Rational(3, 10)*Rational(7, 10), Rational(21, 5))"
          ]
        }
      ],
      "contextIntro": "A factory produces components, $30\\%$ of which are painted red. A random sample of $20$ components is taken. Let $X$ be the number that are red, so $X \\sim B(20,\\, 0.3)$."
    },
    {
      "source": "IB-AAHL-P2-T2-Q3",
