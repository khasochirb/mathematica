          "marks": 5,
          "markscheme": [
            {
              "mark": "M1",
              "note": "displacement $= \\int_0^4 v(t)\\,dt$"
            },
            {
              "mark": "A1",
              "note": "antiderivative $t^3 - 6t^2 + 9t$"
            },
            {
              "mark": "A1",
              "note": "evaluate at $t = 4$: $64 - 96 + 36$"
            },
            {
              "mark": "M1",
              "note": "subtract the value at $t = 0$ (which is 0)"
