    {
      "source": "IB-AASL-P1-T2-Q1",
      "number": 1,
      "section": "A",
      "maximumMark": 5,
      "topic": "number_algebra",
      "skill_tag": "geometric_sequences",
      "parts": [
        {
          "label": "a",
          "body": "Find the common ratio $r$.",
          "marks": 2,
          "markscheme": [
            {
              "mark": "M1",
              "note": "attempt to use $u_3 = u_1 r^2$, i.e. $12 = 3r^2$"
            },
            {
              "mark": "A1",
              "note": "$r = 2$"
            }
          ],
          "answer": "$r = 2$",
          "solution": "**Plan:** the third term is two ratio-steps beyond the first. $$u_3 = u_1 r^2 \\Rightarrow 12 = 3r^2$$$$r^2 = 4 \\Rightarrow r = 2 \\;(r > 0)$$",
          "verify": [
            "Eq(3*2**2, 12)"
          ]
        },
        {
          "label": "b",
          "body": "Find the fifth term $u_5$.",
          "marks": 1,
          "markscheme": [
            {
              "mark": "A1",
              "note": "$u_5 = 48$"
            }
          ],
          "answer": "$u_5 = 48$",
          "solution": "$$u_5 = u_1 r^4 = 3 \\cdot 2^4 = 3 \\cdot 16 = 48$$",
          "verify": [
            "Eq(3*2**4, 48)"
          ]
        },
        {
          "label": "c",
          "body": "Find the sum of the first six terms, $S_6$.",
          "marks": 2,
          "markscheme": [
            {
              "mark": "M1",
              "note": "attempt to use $S_n = \\dfrac{u_1(r^n - 1)}{r - 1}$"
            },
            {
              "mark": "A1",
              "note": "$S_6 = 189$"
            }
          ],
          "answer": "$S_6 = 189$",
          "solution": "$$S_6 = \\frac{u_1(r^6 - 1)}{r - 1} = \\frac{3(2^6 - 1)}{2 - 1} = 3(63) = 189$$",
          "verify": [
            "Eq(3*(2**6 - 1)/(2 - 1), 189)"
          ]
        }
      ],
      "contextIntro": "A geometric sequence has first term $u_1 = 3$ and third term $u_3 = 12$, with a positive common ratio $r$."
    },
    {
