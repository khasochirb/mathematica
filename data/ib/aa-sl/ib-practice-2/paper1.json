      "parts": [
        {
          "label": "a",
          "body": "Find $P(A \\cap B)$.",
          "marks": 2,
          "markscheme": [
            {
              "mark": "M1",
              "note": "use independence: $P(A \\cap B) = P(A)\\,P(B)$"
            },
            {
              "mark": "A1",
              "note": "$P(A \\cap B) = \\dfrac{1}{5}$"
            }
          ],
          "answer": "$\\dfrac{1}{5}$",
          "solution": "For independent events the intersection is the product:$$P(A \\cap B) = \\tfrac{1}{2} \\cdot \\tfrac{2}{5} = \\tfrac{1}{5}$$",
          "verify": [
            "Eq(Rational(1,2)*Rational(2,5), Rational(1,5))"
          ]
        },
        {
          "label": "b",
          "body": "Find $P(A \\cup B)$.",
          "marks": 3,
          "markscheme": [
            {
              "mark": "M1",
              "note": "use $P(A \\cup B) = P(A) + P(B) - P(A \\cap B)$"
            },
            {
              "mark": "A1",
              "note": "$\\tfrac{1}{2} + \\tfrac{2}{5} - \\tfrac{1}{5}$"
            },
            {
              "mark": "A1",
              "note": "$P(A \\cup B) = \\dfrac{7}{10}$"
            }
          ],
          "answer": "$\\dfrac{7}{10}$",
          "solution": "Apply the addition rule:$$P(A \\cup B) = \\tfrac{1}{2} + \\tfrac{2}{5} - \\tfrac{1}{5} = \\tfrac{5}{10} + \\tfrac{4}{10} - \\tfrac{2}{10} = \\tfrac{7}{10}$$",
          "verify": [
            "Eq(Rational(1,2)+Rational(2,5)-Rational(1,5), Rational(7,10))"
          ]
        }
      ],
      "contextIntro": "Two events $A$ and $B$ are independent, with $P(A) = \\dfrac{1}{2}$ and $P(B) = \\dfrac{2}{5}$."
    },
    {
