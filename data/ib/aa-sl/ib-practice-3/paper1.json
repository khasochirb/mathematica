      "maximumMark": 5,
      "topic": "stats_probability",
      "skill_tag": "probability_basics",
      "parts": [
        {
          "label": "a",
          "body": "Find the probability that both counters are red.",
          "marks": 3,
          "markscheme": [
            {
              "mark": "M1",
              "note": "multiply along the branch: $\\tfrac{4}{10} \\times \\tfrac{3}{9}$"
            },
            {
              "mark": "A1",
              "note": "$\\tfrac{12}{90}$"
            },
            {
              "mark": "A1",
              "note": "$= \\dfrac{2}{15}$"
            }
          ],
          "answer": "$\\dfrac{2}{15}$",
          "solution": "After one red is taken, 3 of the remaining 9 are red:$$P(RR) = \\frac{4}{10} \\cdot \\frac{3}{9} = \\frac{12}{90} = \\frac{2}{15}$$",
          "verify": [
            "Eq(Rational(4, 10)*Rational(3, 9), Rational(2, 15))"
          ]
        },
        {
          "label": "b",
          "body": "Given that the first counter is blue, write down the probability that the second counter is red.",
          "marks": 2,
          "markscheme": [
            {
              "mark": "M1",
              "note": "after one blue is removed, 9 counters remain, 4 red"
            },
            {
              "mark": "A1",
              "note": "$P = \\dfrac{4}{9}$"
            }
          ],
          "answer": "$\\dfrac{4}{9}$",
          "solution": "Removing a blue counter leaves 4 red among 9:$$P(\\text{2nd red} \\mid \\text{1st blue}) = \\frac{4}{9}$$",
          "verify": [
            "Eq(Rational(4, 9), Rational(4, 9))",
            "Eq(4 + 5, 9)"
          ]
        }
      ],
      "contextIntro": "A bag contains 4 red and 6 blue counters. Two counters are taken from the bag at random, one after the other, WITHOUT replacement."
    },
    {
      "source": "IB-AASL-P1-T3-Q3",
