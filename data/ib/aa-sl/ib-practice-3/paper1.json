    {
      "source": "IB-AASL-P1-T3-Q1",
      "number": 1,
      "section": "A",
      "maximumMark": 5,
      "topic": "number_algebra",
      "skill_tag": "arithmetic_sequences",
      "parts": [
        {
          "label": "a",
          "body": "Find $u_{10}$.",
          "marks": 2,
          "markscheme": [
            {
              "mark": "M1",
              "note": "use $u_n = u_1 + (n - 1)d$"
            },
            {
              "mark": "A1",
              "note": "$u_{10} = 5 + 9(3) = 32$"
            }
          ],
          "answer": "$u_{10} = 32$",
          "solution": "$$u_{10} = u_1 + 9d = 5 + 27 = 32$$",
          "verify": [
            "Eq(5 + 9*3, 32)"
          ]
        },
        {
          "label": "b",
          "body": "Find $S_{10}$, the sum of the first ten terms.",
          "marks": 3,
          "markscheme": [
            {
              "mark": "M1",
              "note": "use $S_n = \\tfrac{n}{2}(2u_1 + (n - 1)d)$"
            },
            {
              "mark": "A1",
              "note": "$S_{10} = 5(10 + 27)$"
            },
            {
              "mark": "A1",
              "note": "$S_{10} = 185$"
            }
          ],
          "answer": "$S_{10} = 185$",
          "solution": "$$S_{10} = \\frac{10}{2}\\big(2(5) + 9(3)\\big) = 5(37) = 185$$",
          "verify": [
            "Eq(Rational(10, 2)*(2*5 + 9*3), 185)"
          ]
        }
      ],
      "contextIntro": "An arithmetic sequence has first term $u_1 = 5$ and common difference $d = 3$."
    },
    {
