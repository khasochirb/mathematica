      "section": "A",
      "maximumMark": 6,
      "topic": "functions",
      "skill_tag": "composite_inverse",
      "parts": [
        {
          "label": "a",
          "body": "Find $(f \\circ g)(2)$.",
          "marks": 2,
          "markscheme": [
            {
              "mark": "M1",
              "note": "evaluate $g(2) = 4$ first"
            },
            {
              "mark": "A1",
              "note": "$(f \\circ g)(2) = f(4) = 5$"
            }
          ],
          "answer": "$5$",
          "solution": "$$g(2) = 4, \\qquad f(4) = 2(4) - 3 = 5$$",
          "verify": [
            "Eq(2*(2**2) - 3, 5)"
          ]
        },
        {
          "label": "b",
          "body": "Find $f^{-1}(x)$.",
          "marks": 2,
          "markscheme": [
            {
              "mark": "M1",
              "note": "swap and solve: $x = 2y - 3$"
            },
            {
              "mark": "A1",
              "note": "$f^{-1}(x) = \\dfrac{x + 3}{2}$"
            }
          ],
          "answer": "$f^{-1}(x) = \\dfrac{x + 3}{2}$",
          "solution": "Write $y = 2x - 3$, swap variables and solve:$$x = 2y - 3 \\Rightarrow y = \\frac{x + 3}{2}$$",
          "verify": [
            "Eq((2*5 - 3 + 3)/2, 5)"
          ]
        },
        {
          "label": "c",
          "body": "Solve $f^{-1}(x) = 5$.",
          "marks": 2,
          "markscheme": [
            {
              "mark": "M1",
              "note": "apply $f$ to both sides (or solve directly)"
            },
            {
              "mark": "A1",
              "note": "$x = f(5) = 7$"
            }
          ],
          "answer": "$x = 7$",
          "solution": "$$\\frac{x + 3}{2} = 5 \\Rightarrow x + 3 = 10 \\Rightarrow x = 7$$",
          "verify": [
            "Eq(Rational(7 + 3, 2), 5)"
          ]
        }
      ],
      "contextIntro": "The functions $f$ and $g$ are defined by $f(x) = 2x - 3$ and $g(x) = x^2$."
    },
    {
