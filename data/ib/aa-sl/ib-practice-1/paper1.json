            "Eq(simplify(((2*x + 3)/(x - 1) + 3)/((2*x + 3)/(x - 1) - 2) - x), 0)"
          ]
        }
      ],
      "contextIntro": "Let $f(x) = \\dfrac{2x + 3}{x - 1}$ for $x \\ne 1$, and $g(x) = x + 2$."
