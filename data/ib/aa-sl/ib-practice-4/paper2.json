      "number": 9,
      "section": "B",
      "maximumMark": 15,
      "topic": "calculus",
      "skill_tag": "kinematics",
      "parts": [
        {
          "label": "a",
          "body": "Find the times at which $P$ is at rest.",
          "marks": 2,
          "markscheme": [
            {
              "mark": "M1",
              "note": "solve $v(t) = 0$: $(t - 1)(t - 3) = 0$"
            },
            {
              "mark": "A1",
              "note": "$t = 1$ and $t = 3$"
            }
          ],
          "answer": "$t = 1$ and $t = 3$ seconds",
          "solution": "$$v(t) = t^2 - 4t + 3 = (t - 1)(t - 3) = 0 \\Rightarrow t = 1, 3.$$",
          "verify": [
            "Eq(1**2 - 4*1 + 3, 0)",
            "Eq(3**2 - 4*3 + 3, 0)"
          ]
        },
        {
          "label": "b",
          "body": "Find the acceleration of $P$ when $t = 2$, and state what this tells you about the motion at that instant.",
          "marks": 3,
          "markscheme": [
            {
              "mark": "M1",
              "note": "$a(t) = v'(t) = 2t - 4$"
            },
            {
              "mark": "A1",
              "note": "$a(2) = 0$"
            },
            {
              "mark": "R1",
              "note": "the velocity is a minimum (speed greatest in that phase) when $a = 0$"
            }
          ],
          "answer": "$a(2) = 0$",
          "solution": "$$a(t) = v'(t) = 2t - 4 \\Rightarrow a(2) = 0.$$ At $t = 2$ the acceleration is zero, so the velocity is momentarily neither increasing nor decreasing (a turning point of $v$).",
          "verify": [
            "Eq(diff(t**2 - 4*t + 3, t).subs(t, 2), 0)"
          ]
        },
        {
          "label": "c",
          "body": "Find the displacement of $P$ from its starting point over the interval $0 \\le t \\le 4$.",
          "marks": 3,
          "markscheme": [
            {
              "mark": "M1",
              "note": "displacement $= \\displaystyle\\int_0^4 v(t)\\,dt$"
            },
            {
              "mark": "A1",
              "note": "antiderivative $\\tfrac{t^3}{3} - 2t^2 + 3t$"
            },
            {
              "mark": "A1",
              "note": "$\\dfrac{4}{3}$ m"
            }
          ],
          "answer": "$\\dfrac{4}{3}$ m",
          "solution": "$$\\int_0^4 (t^2 - 4t + 3)\\,dt = \\left[\\frac{t^3}{3} - 2t^2 + 3t\\right]_0^4 = \\frac{64}{3} - 32 + 12 = \\frac{4}{3} \\text{ m}.$$",
          "verify": [
            "Eq(integrate(t**2 - 4*t + 3, (t, 0, 4)), Rational(4, 3))"
          ]
        },
        {
          "label": "d",
          "body": "Find the total distance travelled by $P$ over the interval $0 \\le t \\le 4$.",
          "marks": 4,
          "markscheme": [
            {
              "mark": "M1",
              "note": "the velocity changes sign at $t = 1$ and $t = 3$"
            },
            {
              "mark": "M1",
              "note": "integrate over each interval and take absolute values"
            },
            {
              "mark": "A1",
              "note": "$\\tfrac43 + \\tfrac43 + \\tfrac43$"
            },
            {
              "mark": "A1",
              "note": "total distance $= 4$ m"
            }
          ],
          "answer": "$4$ m",
          "solution": "$v > 0$ on $(0, 1)$ and $(3, 4)$ and $v < 0$ on $(1, 3)$:$$\\int_0^1 v = \\frac43, \\quad \\int_1^3 v = -\\frac43, \\quad \\int_3^4 v = \\frac43,$$$$\\text{distance} = \\frac43 + \\frac43 + \\frac43 = 4 \\text{ m}.$$",
          "verify": [
            "Eq(integrate(t**2 - 4*t + 3, (t, 0, 1)), Rational(4,3))",
            "Eq(integrate(t**2 - 4*t + 3, (t, 1, 3)), Rational(-4,3))",
            "Eq(integrate(t**2 - 4*t + 3, (t, 3, 4)), Rational(4,3))"
          ]
        },
        {
          "label": "e",
          "body": "Find the maximum speed of $P$ over the interval $0 \\le t \\le 4$.",
          "marks": 3,
          "markscheme": [
            {
              "mark": "M1",
              "note": "check the velocity at the endpoints and the turning point"
            },
            {
              "mark": "A1",
              "note": "$v(0) = 3$, $v(2) = -1$, $v(4) = 3$"
            },
            {
              "mark": "A1",
              "note": "maximum speed $= 3$ m s$^{-1}$"
            }
          ],
          "answer": "$3$ m s$^{-1}$",
          "solution": "Speed is $|v|$. The interior turning point gives $v(2) = -1$ (speed $1$), while the endpoints give $v(0) = v(4) = 3$:$$\\text{maximum speed} = 3 \\text{ m s}^{-1}.$$",
          "verify": [
            "Eq((t**2 - 4*t + 3).subs(t, 0), 3)",
            "Eq((t**2 - 4*t + 3).subs(t, 2), -1)",
            "Eq((t**2 - 4*t + 3).subs(t, 4), 3)"
          ]
        }
      ],
      "contextIntro": "A particle $P$ moves in a straight line. Its velocity, in m s$^{-1}$, at time $t$ seconds is given by $v(t) = t^2 - 4t + 3$ for $0 \\le t \\le 4$."
    }
  ]
}
