  "questions": [
    {
      "source": "IB-AASL-P2-T4-Q1",
      "number": 1,
      "section": "A",
      "maximumMark": 6,
      "topic": "functions",
      "skill_tag": "exponential_functions",
      "parts": [
        {
          "label": "a",
          "body": "Write down the value of $f(0)$.",
          "marks": 1,
          "markscheme": [
            {
              "mark": "A1",
              "note": "$f(0) = 3$"
            }
          ],
          "answer": "$f(0) = 3$",
          "solution": "$$f(0) = 3 \\times 2^{0} = 3.$$",
          "verify": [
            "Eq(3*2**0, 3)"
          ]
        },
        {
          "label": "b",
          "body": "Find the value of $x$ for which $f(x) = 48$.",
          "marks": 2,
          "markscheme": [
            {
              "mark": "M1",
              "note": "$2^{x} = 16$"
            },
            {
              "mark": "A1",
              "note": "$x = 4$"
            }
          ],
          "answer": "$x = 4$",
          "solution": "$$3 \\times 2^{x} = 48 \\Rightarrow 2^{x} = 16 = 2^4 \\Rightarrow x = 4.$$",
          "verify": [
            "Eq(3*2**4, 48)"
          ]
        },
        {
          "label": "c",
          "body": "Solve $f(x) = 100$, giving your answer to three significant figures.",
          "marks": 3,
          "markscheme": [
            {
              "mark": "M1",
              "note": "$2^{x} = \\dfrac{100}{3}$"
            },
            {
              "mark": "M1",
              "note": "take logarithms: $x = \\dfrac{\\ln(100/3)}{\\ln 2}$"
            },
            {
              "mark": "A1",
              "note": "$x = 5.06$ $(5.05889\\ldots)$"
            }
          ],
          "answer": "$x = 5.06$",
          "solution": "$$3 \\times 2^{x} = 100 \\Rightarrow 2^{x} = \\frac{100}{3}$$$$x = \\frac{\\ln(100/3)}{\\ln 2} = 5.05889 \\approx 5.06.$$",
          "verify": [
            "Abs(log(Rational(100, 3))/log(2) - 5.06) < 0.0051"
          ]
        }
      ],
      "contextIntro": "The function $f$ is defined by $f(x) = 3 \\times 2^{x}$."
    },
    {
      "source": "IB-AASL-P2-T4-Q2",
      "number": 2,
      "section": "A",
      "maximumMark": 6,
      "topic": "stats_probability",
      "skill_tag": "binomial_distribution",
      "parts": [
        {
          "label": "a",
          "body": "Find $P(X = 3)$.",
          "marks": 2,
          "markscheme": [
            {
              "mark": "M1",
              "note": "binomial pdf $\\binom{8}{3}(0.35)^3(0.65)^5$ (or GDC)"
            },
            {
              "mark": "A1",
              "note": "$P(X = 3) = 0.279$ $(0.278586\\ldots)$"
            }
          ],
          "answer": "$0.279$",
          "solution": "$$P(X = 3) = \\binom{8}{3}(0.35)^3(0.65)^5 = 0.278586 \\approx 0.279.$$",
          "verify": [
            "Abs(binomial(8, 3)*Rational(35,100)**3*Rational(65,100)**5 - 0.279) < 0.00051"
          ]
        },
        {
          "label": "b",
          "body": "Find $P(X \\le 2)$.",
          "marks": 2,
          "markscheme": [
            {
              "mark": "M1",
              "note": "binomial cdf up to $2$ (or sum $k = 0, 1, 2$)"
            },
            {
              "mark": "A1",
              "note": "$P(X \\le 2) = 0.428$ $(0.427814\\ldots)$"
            }
          ],
          "answer": "$0.428$",
          "solution": "$$P(X \\le 2) = \\sum_{k=0}^{2}\\binom{8}{k}(0.35)^k(0.65)^{8-k} = 0.427814 \\approx 0.428.$$",
          "verify": [
            "Abs((Rational(65,100)**8 + 8*Rational(35,100)*Rational(65,100)**7 + 28*Rational(35,100)**2*Rational(65,100)**6) - 0.428) < 0.00051"
          ]
        },
        {
          "label": "c",
          "body": "Write down $E(X)$.",
          "marks": 2,
          "markscheme": [
            {
              "mark": "M1",
              "note": "use $E(X) = np$"
            },
            {
              "mark": "A1",
              "note": "$E(X) = 2.8$"
            }
          ],
          "answer": "$E(X) = 2.8$",
          "solution": "$$E(X) = np = 8 \\times 0.35 = 2.8.$$",
          "verify": [
            "Eq(8*Rational(35,100), Rational(14,5))"
          ]
        }
      ],
      "contextIntro": "A biased coin lands on heads with probability $0.35$. The coin is tossed $8$ times. Let $X$ be the number of heads, so $X \\sim B(8,\\, 0.35)$."
    },
