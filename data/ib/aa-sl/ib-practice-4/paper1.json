          "marks": 2,
          "markscheme": [
            {
              "mark": "M1",
              "note": "use $\\cos 2\\theta = 2\\cos^2\\theta - 1$"
            },
            {
              "mark": "A1",
              "note": "$\\cos 2\\theta = -\\dfrac{7}{25}$"
            }
          ],
          "answer": "$\\cos 2\\theta = -\\dfrac{7}{25}$",
          "solution": "$$\\cos 2\\theta = 2\\cos^2\\theta - 1 = 2 \\cdot \\frac{9}{25} - 1 = \\frac{18}{25} - \\frac{25}{25} = -\\frac{7}{25}.$$",
          "verify": [
            "Eq(2*Rational(3, 5)**2 - 1, Rational(-7, 25))"
          ]
        }
      ],
      "contextIntro": "The angle $\\theta$ is acute and $\\cos\\theta = \\dfrac{3}{5}$."
    },
    {
