    {
      "source": "IB-AASL-P1-T4-Q1",
      "number": 1,
      "section": "A",
      "maximumMark": 5,
      "topic": "number_algebra",
      "skill_tag": "geometric_series",
      "parts": [
        {
          "label": "a",
          "body": "Find $u_3$.",
          "marks": 2,
          "markscheme": [
            {
              "mark": "M1",
              "note": "use $u_n = u_1 r^{\\,n-1}$"
            },
            {
              "mark": "A1",
              "note": "$u_3 = 12\\left(\\tfrac{1}{3}\\right)^2 = \\tfrac{4}{3}$"
            }
          ],
          "answer": "$u_3 = \\dfrac{4}{3}$",
          "solution": "$$u_3 = 12\\left(\\frac{1}{3}\\right)^{2} = \\frac{12}{9} = \\frac{4}{3}.$$",
          "verify": [
            "Eq(12*Rational(1, 3)**2, Rational(4, 3))"
          ]
        },
        {
          "label": "b",
          "body": "Find the sum to infinity of the sequence.",
          "marks": 3,
          "markscheme": [
            {
              "mark": "M1",
              "note": "use $S_\\infty = \\dfrac{u_1}{1 - r}$ (valid since $|r| < 1$)"
            },
            {
              "mark": "A1",
              "note": "$\\dfrac{12}{1 - \\tfrac{1}{3}}$"
            },
            {
              "mark": "A1",
              "note": "$S_\\infty = 18$"
            }
          ],
          "answer": "$S_\\infty = 18$",
          "solution": "Since $|r| = \\tfrac13 < 1$ the series converges:$$S_\\infty = \\frac{u_1}{1 - r} = \\frac{12}{1 - \\tfrac13} = \\frac{12}{\\tfrac23} = 18.$$",
          "verify": [
            "Eq(12/(1 - Rational(1, 3)), 18)"
          ]
        }
      ],
      "contextIntro": "A geometric sequence has first term $u_1 = 12$ and common ratio $r = \\dfrac{1}{3}$."
    },
    {
      "source": "IB-AASL-P1-T4-Q2",
      "number": 2,
      "section": "A",
      "maximumMark": 5,
      "topic": "stats_probability",
      "skill_tag": "set_probability",
      "parts": [
        {
          "label": "a",
          "body": "Find $P(A \\cap B)$.",
          "marks": 2,
          "markscheme": [
            {
              "mark": "M1",
              "note": "use $P(A \\cup B) = P(A) + P(B) - P(A \\cap B)$"
            },
            {
              "mark": "A1",
              "note": "$P(A \\cap B) = \\dfrac{1}{5}$"
            }
          ],
          "answer": "$P(A \\cap B) = \\dfrac{1}{5}$",
          "solution": "$$P(A \\cap B) = P(A) + P(B) - P(A \\cup B) = \\frac12 + \\frac25 - \\frac{7}{10} = \\frac{1}{5}.$$",
          "verify": [
            "Eq(Rational(1, 2) + Rational(2, 5) - Rational(7, 10), Rational(1, 5))"
          ]
        },
        {
          "label": "b",
          "body": "Determine whether $A$ and $B$ are independent, justifying your answer.",
          "marks": 3,
          "markscheme": [
            {
              "mark": "M1",
              "note": "compute $P(A)\\,P(B) = \\tfrac12 \\cdot \\tfrac25$"
            },
            {
              "mark": "A1",
              "note": "$P(A)P(B) = \\dfrac{1}{5}$"
            },
            {
              "mark": "R1",
              "note": "since $P(A \\cap B) = P(A)P(B)$, the events ARE independent"
            }
          ],
          "answer": "independent, since $P(A \\cap B) = P(A)P(B) = \\dfrac{1}{5}$",
          "solution": "$A$ and $B$ are independent exactly when $P(A \\cap B) = P(A)P(B)$. Here$$P(A)P(B) = \\frac12 \\cdot \\frac25 = \\frac15 = P(A \\cap B),$$ so the events are independent.",
          "verify": [
            "Eq(Rational(1, 2)*Rational(2, 5), Rational(1, 5))"
          ]
        }
      ],
      "contextIntro": "For two events $A$ and $B$, $P(A) = \\dfrac{1}{2}$, $P(B) = \\dfrac{2}{5}$ and $P(A \\cup B) = \\dfrac{7}{10}$."
    },
    {
      "source": "IB-AASL-P1-T4-Q3",
      "number": 3,
      "section": "A",
      "maximumMark": 6,
      "topic": "functions",
      "skill_tag": "quadratic_functions",
      "parts": [
        {
          "label": "a",
          "body": "Write $f(x)$ in the form $(x - h)^2 + k$.",
          "marks": 3,
          "markscheme": [
            {
              "mark": "M1",
              "note": "complete the square: half of $-6$ is $-3$"
            },
            {
              "mark": "A1",
              "note": "$(x - 3)^2$ with a correction of $-9$"
            },
            {
              "mark": "A1",
              "note": "$f(x) = (x - 3)^2 - 4$"
            }
          ],
          "answer": "$f(x) = (x - 3)^2 - 4$",
          "solution": "$$f(x) = x^2 - 6x + 5 = (x - 3)^2 - 9 + 5 = (x - 3)^2 - 4.$$",
          "verify": [
            "Eq(expand((x - 3)**2 - 4), x**2 - 6*x + 5)"
          ]
        },
        {
          "label": "b",
          "body": "Hence write down the coordinates of the vertex of the graph of $f$, and find the $x$-intercepts.",
          "marks": 3,
          "markscheme": [
            {
              "mark": "A1",
              "note": "vertex $(3, -4)$"
            },
            {
              "mark": "M1",
              "note": "solve $(x - 3)^2 = 4$, i.e. $x - 3 = \\pm 2$"
            },
            {
              "mark": "A1",
              "note": "$x = 1$ and $x = 5$"
            }
          ],
          "answer": "vertex $(3, -4)$; $x$-intercepts $x = 1$ and $x = 5$",
          "solution": "The vertex form gives the minimum point $(3, -4)$. Setting $f(x) = 0$:$$(x - 3)^2 = 4 \\Rightarrow x - 3 = \\pm 2 \\Rightarrow x = 1 \\text{ or } x = 5.$$",
          "verify": [
            "Eq(1**2 - 6*1 + 5, 0)",
            "Eq(5**2 - 6*5 + 5, 0)"
          ]
        }
      ],
      "contextIntro": "The function $f$ is defined by $f(x) = x^2 - 6x + 5$."
    },
    {
